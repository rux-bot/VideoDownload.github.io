<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>视频下载器 - 支持多平台</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0f0f0f;
            --bg-secondary: #1a1a1a;
            --bg-tertiary: #252525;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --accent: #7c3aed;
            --accent-hover: #6d28d9;
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --border: #333333;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #7c3aed, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .platforms {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .platform-badge {
            background: var(--bg-tertiary);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.85rem;
            border: 1px solid var(--border);
        }

        .input-section {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

        .input-wrapper {
            display: flex;
            gap: 12px;
        }

        input[type="text"] {
            flex: 1;
            padding: 16px 20px;
            background: var(--bg-tertiary);
            border: 2px solid var(--border);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 1rem;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: var(--accent);
        }

        input[type="text"]::placeholder {
            color: var(--text-secondary);
        }

        .btn {
            padding: 16px 32px;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
        }

        .btn-primary:disabled {
            background: #4a4a4a;
            cursor: not-allowed;
            transform: none;
        }

        .btn-secondary {
            background: var(--bg-tertiary);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--border);
        }

        .video-info {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
            display: none;
            border: 1px solid var(--border);
        }

        .video-info.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .video-info-inner {
            display: flex;
            gap: 20px;
        }

        .video-thumbnail {
            width: 200px;
            height: 120px;
            border-radius: 8px;
            object-fit: cover;
            background: var(--bg-tertiary);
        }

        .video-details {
            flex: 1;
        }

        .video-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .video-meta {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        .video-meta span {
            margin-right: 16px;
        }

        .download-section {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 20px;
            display: none;
            border: 1px solid var(--border);
        }

        .download-section.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        .progress-container {
            margin-bottom: 20px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .progress-bar {
            height: 8px;
            background: var(--bg-tertiary);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #ec4899);
            border-radius: 4px;
            transition: width 0.3s ease;
            width: 0%;
        }

        .status-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .download-btn {
            width: 100%;
            padding: 16px;
            background: var(--success);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            display: none;
            transition: all 0.3s;
        }

        .download-btn:hover {
            background: #059669;
        }

        .download-btn.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid var(--error);
            border-radius: 12px;
            padding: 16px;
            color: var(--error);
            display: none;
            margin-bottom: 20px;
        }

        .error-message.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        .history-section {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 24px;
            border: 1px solid var(--border);
        }

        .history-title {
            font-size: 1.2rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .history-item {
            background: var(--bg-tertiary);
            border-radius: 10px;
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .history-item-info h4 {
            font-size: 0.95rem;
            margin-bottom: 4px;
        }

        .history-item-info p {
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .history-item-actions {
            display: flex;
            gap: 8px;
        }

        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            display: inline-block;
            margin-right: 8px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .loading-overlay.show {
            display: flex;
        }

        .loading-content {
            background: var(--bg-secondary);
            padding: 30px;
            border-radius: 16px;
            text-align: center;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--text-secondary);
        }

        @media (max-width: 600px) {
            .input-wrapper {
                flex-direction: column;
            }

            .video-info-inner {
                flex-direction: column;
            }

            .video-thumbnail {
                width: 100%;
                height: 180px;
            }

            h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>视频下载器</h1>
            <p class="subtitle">支持抖音、Bilibili、小红书、YouTube 等主流平台</p>
            <div class="platforms">
                <span class="platform-badge">抖音</span>
                <span class="platform-badge">Bilibili</span>
                <span class="platform-badge">小红书</span>
                <span class="platform-badge">YouTube</span>
                <span class="platform-badge">Twitter/X</span>
                <span class="platform-badge">Instagram</span>
                <span class="platform-badge">微博</span>
                <span class="platform-badge">快手</span>
            </div>
        </header>

        <div class="input-section">
            <div class="input-wrapper">
                <input type="text" id="urlInput" placeholder="粘贴视频链接，例如：https://www.douyin.com/video/...">
                <button class="btn btn-primary" id="extractBtn" onclick="extractVideo()">
                    解析视频
                </button>
                <button class="btn btn-secondary" onclick="clearAll()">清空</button>
            </div>
        </div>

        <div class="error-message" id="errorMessage"></div>

        <div class="video-info" id="videoInfo">
            <div class="video-info-inner">
                <img class="video-thumbnail" id="videoThumbnail" src="" alt="视频封面">
                <div class="video-details">
                    <h3 class="video-title" id="videoTitle"></h3>
                    <div class="video-meta">
                        <span id="videoPlatform"></span>
                        <span id="videoDuration"></span>
                        <span id="videoAuthor"></span>
                    </div>
                    <button class="btn btn-primary" onclick="startDownload()">
                        <span id="downloadBtnText">开始下载 - 最高画质</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="download-section" id="downloadSection">
            <h3 style="margin-bottom: 20px;">下载进度</h3>
            <div class="progress-container">
                <div class="progress-header">
                    <span id="progressStatus">准备中...</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
            </div>
            <div class="status-text" id="statusText"></div>
            <button class="download-btn" id="saveBtn" onclick="saveFile()">
                保存到本地
            </button>
        </div>

        <div class="history-section">
            <div class="history-title">
                <span>下载记录</span>
                <button class="btn btn-secondary" onclick="clearHistory()" style="padding: 8px 16px; font-size: 0.85rem;">
                    清空记录
                </button>
            </div>
            <div class="history-list" id="historyList">
                <div class="empty-state" id="emptyState">
                    暂无下载记录
                </div>
            </div>
        </div>
    </div>

    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-content">
            <div class="spinner" style="width: 40px; height: 40px; margin-bottom: 16px;"></div>
            <p id="loadingText">正在解析视频...</p>
        </div>
    </div>

    <script>
        let currentTaskId = null;
        let pollInterval = null;
        let videoData = null;
        let history = JSON.parse(localStorage.getItem('downloadHistory') || '[]');

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            renderHistory();

            // 回车键触发解析
            document.getElementById('urlInput').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') extractVideo();
            });
        });

        function showError(message) {
            const errorEl = document.getElementById('errorMessage');
            errorEl.textContent = message;
            errorEl.classList.add('show');
        }

        function hideError() {
            document.getElementById('errorMessage').classList.remove('show');
        }

        function showLoading(text = '正在解析视频...') {
            document.getElementById('loadingText').textContent = text;
            document.getElementById('loadingOverlay').classList.add('show');
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').classList.remove('show');
        }

        async function extractVideo() {
            const url = document.getElementById('urlInput').value.trim();
            if (!url) {
                showError('请输入视频链接');
                return;
            }

            hideError();
            showLoading('正在解析视频信息...');
            document.getElementById('extractBtn').disabled = true;

            try {
                const response = await fetch('/api/extract', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url })
                });

                const data = await response.json();

                if (data.error) {
                    showError(data.error);
                    return;
                }

                videoData = data;
                displayVideoInfo(data);

            } catch (error) {
                showError('解析失败，请检查链接是否正确');
                console.error(error);
            } finally {
                hideLoading();
                document.getElementById('extractBtn').disabled = false;
            }
        }

        function displayVideoInfo(data) {
            document.getElementById('videoThumbnail').src = data.thumbnail || 'data:image/svg+xml;base64,';
            document.getElementById('videoTitle').textContent = data.title;
            document.getElementById('videoPlatform').textContent = `平台: ${getPlatformName(data.platform)}`;
            document.getElementById('videoDuration').textContent = `时长: ${formatDuration(data.duration)}`;
            document.getElementById('videoAuthor').textContent = `作者: ${data.uploader || '未知'}`;

            document.getElementById('videoInfo').classList.add('show');
            document.getElementById('downloadSection').classList.remove('show');
        }

        function getPlatformName(platform) {
            const names = {
                'douyin': '抖音',
                'bilibili': 'Bilibili',
                'xiaohongshu': '小红书',
                'youtube': 'YouTube',
                'twitter': 'Twitter/X',
                'instagram': 'Instagram',
                'weibo': '微博',
                'kuaishou': '快手',
                'zhihu': '知乎',
                'other': '其他平台'
            };
            return names[platform] || platform;
        }

        function formatDuration(seconds) {
            if (!seconds) return '未知';
            const mins = Math.floor(seconds / 60);
            const secs = seconds % 60;
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        async function startDownload() {
            const url = document.getElementById('urlInput').value.trim();
            if (!url) return;

            showLoading('正在准备下载...');
            document.getElementById('downloadSection').classList.add('show');
            document.getElementById('saveBtn').classList.remove('show');

            try {
                const response = await fetch('/api/download', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url })
                });

                const data = await response.json();

                if (data.error) {
                    showError(data.error);
                    return;
                }

                currentTaskId = data.task_id;
                startPolling();

            } catch (error) {
                showError('下载启动失败');
                console.error(error);
            } finally {
                hideLoading();
            }
        }

        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);

            pollInterval = setInterval(async () => {
                try {
                    const response = await fetch(`/api/status/${currentTaskId}`);
                    const data = await response.json();

                    updateProgress(data);

                    if (data.status === 'completed' || data.status === 'error') {
                        clearInterval(pollInterval);
                        pollInterval = null;

                        if (data.status === 'completed') {
                            addToHistory(data);
                        }
                    }
                } catch (error) {
                    console.error('轮询失败:', error);
                }
            }, 500);
        }

        function updateProgress(data) {
            const progressFill = document.getElementById('progressFill');
            const progressPercent = document.getElementById('progressPercent');
            const progressStatus = document.getElementById('progressStatus');
            const statusText = document.getElementById('statusText');
            const saveBtn = document.getElementById('saveBtn');

            progressFill.style.width = `${data.progress || 0}%`;
            progressPercent.textContent = `${data.progress || 0}%`;

            switch (data.status) {
                case 'pending':
                    progressStatus.textContent = '等待中...';
                    break;
                case 'starting':
                    progressStatus.textContent = '正在连接...';
                    break;
                case 'downloading':
                    const speed = data.speed ? formatSpeed(data.speed) : '';
                    const eta = data.eta ? `预计 ${data.time_left}秒` : '';
                    progressStatus.textContent = `下载中 ${speed}`;
                    statusText.textContent = eta;
                    break;
                case 'processing':
                    progressStatus.textContent = '处理中...';
                    break;
                case 'completed':
                    progressStatus.textContent = '下载完成!';
                    statusText.textContent = `文件: ${data.filename || '视频文件'}`;
                    saveBtn.classList.add('show');
                    break;
                case 'error':
                    progressStatus.textContent = '下载失败';
                    statusText.textContent = data.error || '未知错误';
                    statusText.style.color = 'var(--error)';
                    break;
            }
        }

        function formatSpeed(bytes) {
            if (!bytes) return '';
            const mb = bytes / 1024 / 1024;
            return `${mb.toFixed(1)} MB/s`;
        }

        function saveFile() {
            if (!currentTaskId) return;
            window.location.href = `/api/download-file/${currentTaskId}`;
        }

        function addToHistory(data) {
            const item = {
                id: data.id,
                title: data.title || '未知视频',
                platform: data.platform,
                filename: data.filename,
                time: new Date().toLocaleString('zh-CN')
            };

            history.unshift(item);
            if (history.length > 20) history.pop();
            localStorage.setItem('downloadHistory', JSON.stringify(history));
            renderHistory();
        }

        function renderHistory() {
            const list = document.getElementById('historyList');
            const emptyState = document.getElementById('emptyState');

            if (history.length === 0) {
                emptyState.style.display = 'block';
                return;
            }

            emptyState.style.display = 'none';
            list.innerHTML = history.map(item => `
                <div class="history-item">
                    <div class="history-item-info">
                        <h4>${item.title}</h4>
                        <p>${getPlatformName(item.platform)} · ${item.time}</p>
                    </div>
                    <div class="history-item-actions">
                        <button class="btn btn-secondary" onclick="redownload('${item.id}')" style="padding: 8px 16px; font-size: 0.85rem;">
                            重新下载
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function redownload(taskId) {
            window.location.href = `/api/download-file/${taskId}`;
        }

        function clearAll() {
            document.getElementById('urlInput').value = '';
            document.getElementById('videoInfo').classList.remove('show');
            document.getElementById('downloadSection').classList.remove('show');
            hideError();
            videoData = null;
            currentTaskId = null;
        }

        function clearHistory() {
            history = [];
            localStorage.removeItem('downloadHistory');
            renderHistory();
        }
    </script>
</body>
</html>
